{
    "name": "wapplersystems/microsoft-graph-mailer",
    "type": "typo3-cms-extension",
    "description": "Microsoft Graph mailer transport for TYPO3 — sends emails via Microsoft 365 Graph API with OAuth2 (uses wapplersystems/oauth-service)",
    "homepage": "https://github.com/WapplerSystems/t3-microsoft-graph-mailer",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "TYPO3",
        "extension",
        "mailer",
        "microsoft-graph",
        "office365",
        "oauth2"
    ],
    "authors": [
        {
            "name": "Sven Wappler",
            "email": "typo3@wappler.systems",
            "role": "Developer",
            "homepage": "https://wappler.systems"
        }
    ],
    "support": {
        "issues": "https://github.com/WapplerSystems/t3-microsoft-graph-mailer/issues",
        "source": "https://github.com/WapplerSystems/t3-microsoft-graph-mailer"
    },
    "require": {
        "php": ">=8.2",
        "typo3/cms-core": "^14",
        "wapplersystems/oauth-service": "^14.2",
        "symfony/mailer": "^7.0",
        "symfony/mime": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "WapplerSystems\\MicrosoftGraphMailer\\": "Classes"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "microsoft_graph_mailer"
        }
    }
}
